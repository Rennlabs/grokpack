#!/usr/bin/env bash
# grok-with-hud — open Grok Build with a bottom HUD pane (tmux)
#
# Layout:
#   ┌─────────────────────────────┐
#   │  grok  (main)               │
#   ├─────────────────────────────┤  ~5 lines
#   │  grok-hud --watch           │
#   └─────────────────────────────┘
#
# Usage:
#   grok-with-hud                 # new tmux session in $PWD
#   grok-with-hud --here          # if already in tmux: split current window
#   grok-with-hud -- args…        # pass args through to grok
#
# Requires: tmux, grok, grok-hud on PATH
set -euo pipefail

HERE=0
GROK_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --here) HERE=1; shift ;;
    --) shift; GROK_ARGS+=("$@"); break ;;
    -h|--help)
      sed -n '2,16p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *) GROK_ARGS+=("$1"); shift ;;
  esac
done

command -v tmux >/dev/null || { echo "tmux required" >&2; exit 1; }
command -v grok >/dev/null || { echo "grok not on PATH" >&2; exit 1; }
command -v grok-hud >/dev/null || { echo "grok-hud not on PATH (~/.local/bin?)" >&2; exit 1; }

CWD="$(pwd -P)"
HUD_CMD="grok-hud -C $(printf %q "$CWD")"
GROK_CMD="grok"
if [[ ${#GROK_ARGS[@]} -gt 0 ]]; then
  GROK_CMD="grok $(printf '%q ' "${GROK_ARGS[@]}")"
fi

if [[ "$HERE" -eq 1 || -n "${TMUX:-}" ]]; then
  # Already in tmux: split current window
  # Kill an existing grok-hud pane in this window (best-effort)
  while IFS= read -r pane_id cmd; do
    if [[ "$cmd" == *grok-hud* ]]; then
      tmux kill-pane -t "$pane_id" 2>/dev/null || true
    fi
  done < <(tmux list-panes -F '#{pane_id} #{pane_start_command}' 2>/dev/null || true)

  tmux split-window -v -l 6 -d -c "$CWD" "$HUD_CMD"
  # stay in current pane (caller already has / will start grok)
  if [[ "$HERE" -eq 1 ]]; then
    # If user asked --here without already running grok, start it in this pane
    if [[ ! -t 0 ]]; then
      :
    fi
    echo "[grok-with-hud] HUD pane attached below. Run grok in this pane if not already."
    echo "  $GROK_CMD"
    # If this shell is free, exec grok
    if [[ "$-" == *i* ]]; then
      :
    fi
    exec bash -lc "$GROK_CMD"
  fi
  exit 0
fi

# Fresh session
SESSION="grok-hud-$(basename "$CWD" | tr -c 'A-Za-z0-9_-' '_' | cut -c1-24)-$$"
tmux new-session -d -s "$SESSION" -c "$CWD" "$GROK_CMD"
tmux split-window -t "$SESSION" -v -l 6 -c "$CWD" "$HUD_CMD"
tmux select-pane -t "$SESSION:0.0"
exec tmux attach -t "$SESSION"
