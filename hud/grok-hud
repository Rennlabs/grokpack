#!/usr/bin/env bash
# grok-hud — stable side-pane status for Grok Build (tmux)
#
# Does NOT use the OMC statusLine renderer (that path flashes / alternates
# between real stats and install-status diagnostics when stdin is empty).
# Instead: one fixed-layout frame, cursor-home redraw (no full clear).
#
# Usage:
#   grok-hud                 # watch $PWD (default interval 2s)
#   grok-hud --once          # single frame
#   grok-hud -i 1            # interval seconds
#   grok-hud -C /path/proj   # project root
set -euo pipefail

INTERVAL=2
ONCE=0
CWD="${PWD}"

usage() {
  sed -n '2,14p' "$0" | sed 's/^# \?//'
  exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage 0 ;;
    --once) ONCE=1; shift ;;
    --no-omc) shift ;; # legacy no-op (OMC renderer removed)
    -i|--interval) INTERVAL="${2:?}"; shift 2 ;;
    -C|--cwd) CWD="${2:?}"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; usage 1 ;;
  esac
done

cd "$CWD"
CWD="$(pwd -P)"
export GROK_HUD_CWD="$CWD"
export GROK_HUD_INTERVAL="$INTERVAL"

# Fixed-layout renderer (python keeps layout stable across ticks)
render_py() {
  python3 - <<'PY'
import json, os, time, subprocess
from pathlib import Path

cwd = Path(os.environ["GROK_HUD_CWD"]).resolve()
interval = os.environ.get("GROK_HUD_INTERVAL", "2")
now = time.time()

def age_s(path: Path) -> str:
    try:
        age = int(now - path.stat().st_mtime)
    except OSError:
        return "?"
    if age < 60:
        return f"{age}s"
    if age < 3600:
        return f"{age // 60}m"
    if age < 86400:
        return f"{age // 3600}h"
    return f"{age // 86400}d"

def read_json(path: Path):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None

def git(*args) -> str:
    try:
        return subprocess.check_output(
            ["git", "-C", str(cwd), *args],
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=2,
        ).strip()
    except Exception:
        return ""

branch = git("rev-parse", "--abbrev-ref", "HEAD") or "?"
# porcelain: one line per dirty path
porcelain = git("status", "--porcelain")
dirty = len([ln for ln in porcelain.splitlines() if ln.strip()]) if porcelain else 0
ahead = behind = 0
ab = git("rev-list", "--left-right", "--count", "@{u}...HEAD")
if ab:
    parts = ab.split()
    if len(parts) == 2:
        behind, ahead = int(parts[0] or 0), int(parts[1] or 0)

omc = cwd / ".omc"
state = omc / "state"
sess_root = state / "sessions"

# newest session dir by mtime
sess_dir = None
if sess_root.is_dir():
    dirs = [p for p in sess_root.iterdir() if p.is_dir()]
    if dirs:
        sess_dir = max(dirs, key=lambda p: p.stat().st_mtime)

sess_id = sess_dir.name[:8] if sess_dir else "—"
sess_age = age_s(sess_dir) if sess_dir else "—"
agents_run = 0
agents_done = 0
if sess_dir:
    st = read_json(sess_dir / "subagent-tracking-state.json") or {}
    agents = st.get("agents") or []
    for a in agents:
        s = (a.get("status") or "").lower()
        if s in ("running", "active", "in_progress", "pending"):
            agents_run += 1
        elif s in ("completed", "done", "success"):
            agents_done += 1

# active modes (only if file mtime < 2h and active=true)
modes = []
for name in ("ralph", "ultrawork", "autopilot", "team"):
    for p in (state / f"{name}-state.json", omc / f"{name}-state.json"):
        if not p.is_file():
            continue
        try:
            if now - p.stat().st_mtime > 2 * 3600:
                continue
        except OSError:
            continue
        o = read_json(p) or {}
        if o.get("active") is True:
            # optional iter badge
            it = o.get("iteration") or o.get("iter") or o.get("current")
            mx = o.get("maxIterations") or o.get("max")
            if it is not None and mx is not None:
                modes.append(f"{name}:{it}/{mx}")
            elif it is not None:
                modes.append(f"{name}:{it}")
            else:
                modes.append(name)
        break

# verifiers: only the most recently touched one (avoid long alternating dumps)
ver_line = "—"
if state.is_dir():
    vers = sorted(
        state.glob("*-verifier.json"),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )
    if vers:
        p = vers[0]
        o = read_json(p) or {}
        result = o.get("result") or o.get("status") or o.get("verdict") or "?"
        ver_line = f"{p.stem}={result} ({age_s(p)})"

# mission (compact)
mission = "—"
ms = read_json(state / "mission-state.json") if state.is_dir() else None
if isinstance(ms, dict):
    missions = ms.get("missions") or []
    open_m = [m for m in missions if (m.get("status") or "").lower() not in ("done", "completed", "cancelled")]
    if open_m:
        m = open_m[0]
        mission = f"{m.get('name') or m.get('id') or '?'}:{m.get('status')}"
    elif missions:
        mission = f"done({len(missions)})"

sync = ""
if ahead or behind:
    sync = f"  ↑{ahead}↓{behind}"

# Fixed 6 lines — always the same structure so the pane doesn't "jump"
lines = [
    f"grok-hud  {time.strftime('%H:%M:%S')}  every {interval}s",
    f"repo:{cwd.name}  branch:{branch}  dirty:{dirty}{sync}",
    f"session:{sess_id}  age:{sess_age}  agents:{agents_run} run / {agents_done} done",
    f"modes:{','.join(modes) if modes else '—'}",
    f"mission:{mission}",
    f"verifier:{ver_line}",
]

# Pad / truncate each line so redraw covers previous longer content
width = 96
out = []
for ln in lines:
    # strip control chars; hard-cap width
    ln = "".join(ch for ch in ln if ch >= " " or ch in "\t")
    if len(ln) > width:
        ln = ln[: width - 1] + "…"
    out.append(ln.ljust(width))

print("\n".join(out), end="")
PY
}

draw() {
  # Build full frame first, then paint in one shot (no mid-frame flash).
  local frame
  frame="$(render_py)"

  if [[ -t 1 ]]; then
    # Cursor home + paint + erase anything below (no full-screen blink).
    printf '\033[H%s\033[J' "$frame"
  else
    printf '%s\n' "$frame"
  fi
}

if [[ "$ONCE" -eq 1 ]]; then
  draw
  printf '\n'
  exit 0
fi

trap 'printf "\n[grok-hud] stopped\n"; exit 0' INT TERM

# Hide cursor in the pane while watching
if [[ -t 1 ]]; then
  printf '\033[?25l'
  trap 'printf "\033[?25h\n[grok-hud] stopped\n"; exit 0' INT TERM EXIT
fi

while true; do
  draw
  sleep "$INTERVAL"
done
